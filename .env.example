# Sanity CMS — maak een gratis project op https://sanity.io
# Kopieer dit bestand naar .env.local en vul je project-ID in.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Secret voor de Sanity-revalidatie-webhook (zelf verzinnen, bijv. een lange random string)
SANITY_REVALIDATE_SECRET=
